SMTP_USER=
SMTP_PASS=
SMTP_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_EMAILS=
OPS_ALERT_EMAILS=
OPS_ALERT_TELEGRAM_CHAT_ID=

CFTC_BULLISH=false
CFTC_MM_NET=0
CFTC_UPDATED=1970-01-01

# Public Myfxbook embed URL for the /track-record page (optional until a live account exists)
NEXT_PUBLIC_MYFXBOOK_EMBED_URL=
DEEPSEEK_API_KEY=

# --- Paid-ads tracking (all optional; each block is a no-op until its id is set) ---
# Browser pixels (exposed to the client):
NEXT_PUBLIC_GA4_ID=                       # Google Analytics 4 — "G-XXXXXXXXXX"
NEXT_PUBLIC_GOOGLE_ADS_ID=                # Google Ads — "AW-XXXXXXXXX"
NEXT_PUBLIC_GOOGLE_ADS_PURCHASE_LABEL=    # Purchase conversion — "AW-XXXXXXXXX/abcDEFghIJklMN"
NEXT_PUBLIC_META_PIXEL_ID=                # Meta (Facebook) Pixel id
NEXT_PUBLIC_TIKTOK_PIXEL_ID=              # TikTok Pixel id
# Server-side conversion APIs (secrets — never exposed to the browser):
META_CAPI_ACCESS_TOKEN=                   # Meta Conversions API token
META_TEST_EVENT_CODE=                     # optional, for Meta Events Manager test traffic
GA4_API_SECRET=                           # GA4 Measurement Protocol api_secret
TIKTOK_EVENTS_ACCESS_TOKEN=               # TikTok Events API access token

# Blog agent API — key for external writing agents to draft/publish posts via /api/agent/blog
BLOG_AGENT_API_KEY=
# Set to "true" to let the agent publish directly; otherwise agent writes are forced to draft for human review
BLOG_AGENT_ALLOW_PUBLISH=false

# One-tap owner approval links for the TiGold free-license flow (Telegram).
# Must MATCH licenseApproveSecret in /opt/dralvo-chat/config.json on the VPS.
LICENSE_APPROVE_SECRET=
# Telegram chat id that receives the license-approval messages (the owner).
# Get it by messaging @dralvo_bot then reading the chat id from the webhook log,
# or via @userinfobot. Used by /api/agent/ops/request-license-approval.
OWNER_TELEGRAM_CHAT_ID=
